# --- Project discovery -------------------------------------------------------
# Your GitHub username. The hub lists your public repos carrying the topic below.
GITHUB_USER=your-github-username

# Repos with this topic are shown. Add the topic to a repo -> it appears here.
PORTFOLIO_TOPIC=portfolio

# Optional: a classic/fine-grained PAT with public repo read.
# Without it, discovery uses the 60 req/hr unauthenticated limit (fine for ISR).
# With it, 5000 req/hr and slightly richer data.
GITHUB_TOKEN=

# --- Revalidation ------------------------------------------------------------
# Shared secret for POST /api/revalidate (a spoke calls this after it deploys).
REVALIDATE_SECRET=change-me
